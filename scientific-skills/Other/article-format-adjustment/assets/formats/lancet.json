{
  "name": "The Lancet",
  "version": "1.0",
  "description": "The Lancet 医学期刊格式",
  "font": {
    "body": "Times New Roman",
    "body_size": 10,
    "title": "Helvetica/Arial",
    "title_size": 14,
    "caption": "Times New Roman",
    "caption_size": 8,
    "header": "Times New Roman",
    "footer": "Times New Roman"
  },
  "spacing": {
    "line_space": "single",
    "paragraph_space": 6,
    "indent": 0
  },
  "margins": {
    "top": 2.5,
    "bottom": 2.5,
    "left": 2.5,
    "right": 2.5
  },
  "references": {
    "style": "Lancet",
    "format": "numbered"
  },
  "figures": {
    "caption_position": "below",
    "font_size": 8,
    "font": "Times New Roman"
  },
  "tables": {
    "caption_position": "above",
    "font_size": 8,
    "font": "Times New Roman",
    "borders": true
  },
  "abbreviations": {
    "vs.": "versus",
    "per": "p",
    "wk": "week",
    "mo": "month",
    "yr": "year"
  }
}
