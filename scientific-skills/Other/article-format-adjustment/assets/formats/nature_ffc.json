{
  "name": "Nature Formatting Guide",
  "version": "1.0",
  "description": "Nature期刊格式要求 - 基于官方Formatting Guide",
  "font": {
    "body": "Times New Roman",
    "body_size": 12,
    "title": "Times New Roman",
    "title_size": 12,
    "caption": "Times New Roman",
    "caption_size": 9,
    "header": "Times New Roman",
    "footer": "Times New Roman"
  },
  "spacing": {
    "line_space": "double",
    "paragraph_space": 6,
    "indent": 0
  },
  "margins": {
    "top": 2.54,
    "bottom": 2.54,
    "left": 2.54,
    "right": 2.54
  },
  "references": {
    "style": "Nature",
    "format": "superscript"
  },
  "figures": {
    "caption_position": "below",
    "font_size": 9,
    "font": "Times New Roman",
    "legend_max_words": 300
  },
  "tables": {
    "caption_position": "above",
    "font_size": 9,
    "font": "Times New Roman",
    "title_bold": true,
    "borders": false,
    "orientation": "portrait"
  },
  "document": {
    "max_word_count": 2500,
    "max_references": 50,
    "summary_max_words": 200,
    "subheading_max_chars": 40,
    "page_width_mm": 90,
    "full_depth_mm": 170
  },
  "requirements": {
    "font": "Times New Roman 12pt",
    "spacing": "Double-spaced",
    "references": "Superscript numbers",
    "title_max_chars": 75,
    "sections_order": [
      "Title",
      "Authors",
      "Affiliations",
      "Summary paragraph",
      "Main text",
      "References",
      "Tables",
      "Figure legends",
      "Methods",
      "Methods references",
      "Acknowledgements",
      "Author contributions",
      "Competing interests",
      "Additional information"
    ]
  },
  "abbreviations": {
    "Fig.": "Figure",
    "et al.": "et alii",
    "e.g.": "for example",
    "i.e.": "that is"
  }
}
