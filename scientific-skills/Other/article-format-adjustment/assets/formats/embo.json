{
  "name": "EMBO",
  "version": "1.0",
  "description": "EMBO Journal (European Molecular Biology Organization)",
  "font": {
    "body": "Arial",
    "body_size": 10,
    "title": "Arial",
    "title_size": 14,
    "caption": "Arial",
    "caption_size": 9,
    "header": "Arial",
    "footer": "Arial"
  },
  "spacing": {
    "line_space": "single",
    "paragraph_space": 6,
    "indent": 0
  },
  "margins": {
    "top": 2.54,
    "bottom": 2.54,
    "left": 2.54,
    "right": 2.54
  },
  "references": {
    "style": "EMBO",
    "format": "author-date"
  },
  "figures": {
    "caption_position": "below",
    "font_size": 9,
    "font": "Arial"
  },
  "tables": {
    "caption_position": "above",
    "font_size": 9,
    "font": "Arial",
    "borders": true,
    "title_bold": true
  },
  "document": {
    "max_words": 5000,
    "max_references": 60,
    "max_figures": 7,
    "max_tables": 7
  },
  "abbreviations": {
    "Fig.": "Figure",
    "Fig": "Figure",
    "Table": "Table",
    "et al.": "et al.",
    "vs.": "versus",
    "e.g.": "for example",
    "i.e.": "that is",
    "etc.": "et cetera"
  }
}
