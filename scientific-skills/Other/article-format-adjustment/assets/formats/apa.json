{
  "name": "APA 7th Edition",
  "version": "1.0",
  "font": {
    "body": "Times New Roman",
    "body_size": 12,
    "title": "Times New Roman",
    "title_size": 12,
    "caption": "Times New Roman",
    "caption_size": 10,
    "header": "Times New Roman",
    "footer": "Times New Roman"
  },
  "spacing": {
    "line_space": "double",
    "paragraph_space": 0,
    "indent": 0.5
  },
  "margins": {
    "top": 2.54,
    "bottom": 2.54,
    "left": 2.54,
    "right": 2.54
  },
  "references": {
    "style": "APA",
    "format": "author-date"
  },
  "figures": {
    "caption_position": "below",
    "font_size": 10,
    "font": "Times New Roman"
  },
  "tables": {
    "caption_position": "above",
    "font_size": 10,
    "font": "Times New Roman",
    "borders": false
  },
  "abbreviations": {
    "p.": "page",
    "pp.": "pages",
    "Vol.": "Volume",
    "Ed.": "Editor"
  }
}
