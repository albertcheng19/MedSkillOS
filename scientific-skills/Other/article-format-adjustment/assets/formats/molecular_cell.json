{
  "name": "Molecular Cell",
  "version": "1.0",
  "description": "Molecular Cell 期刊模板 (Cell Press)",
  "font": {
    "body": "Arial",
    "body_size": 11,
    "title": "Arial",
    "title_size": 18,
    "caption": "Arial",
    "caption_size": 9,
    "header": "Arial",
    "footer": "Arial"
  },
  "spacing": {
    "line_space": "double",
    "paragraph_space": 6,
    "indent": 0
  },
  "margins": {
    "top": 2.54,
    "bottom": 2.54,
    "left": 2.54,
    "right": 2.54
  },
  "references": {
    "style": "Molecular Cell",
    "format": "numbered"
  },
  "figures": {
    "caption_position": "below",
    "font_size": 9,
    "font": "Arial",
    "title_required": true
  },
  "tables": {
    "caption_position": "above",
    "font_size": 9,
    "font": "Arial",
    "borders": true,
    "title_bold": true
  },
  "document": {
    "max_words": 6000,
    "max_references": 50,
    "max_figures": 7,
    "max_tables": 7
  },
  "abbreviations": {
    "Fig.": "Figure",
    "Fig": "Figure",
    "Table": "Table",
    "et al.": "et al.",
    "e.g.": "for example",
    "i.e.": "that is",
    "vs.": "versus",
    "et al.": "et al."
  }
}
