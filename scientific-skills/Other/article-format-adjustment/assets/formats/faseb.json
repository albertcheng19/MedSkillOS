{
  "name": "FASEB Journal",
  "version": "1.0",
  "description": "FASEB Journal 期刊模板",
  "font": {
    "body": "Times New Roman",
    "body_size": 12,
    "title": "Arial",
    "title_size": 14,
    "caption": "Times New Roman",
    "caption_size": 10,
    "header": "Times New Roman",
    "footer": "Times New Roman"
  },
  "spacing": {
    "line_space": "double",
    "paragraph_space": 6,
    "indent": 0.5
  },
  "margins": {
    "top": 2.54,
    "bottom": 2.54,
    "left": 2.54,
    "right": 2.54
  },
  "references": {
    "style": "FASEB",
    "format": "numbered"
  },
  "figures": {
    "caption_position": "below",
    "font_size": 10,
    "font": "Times New Roman"
  },
  "tables": {
    "caption_position": "above",
    "font_size": 10,
    "font": "Times New Roman",
    "borders": true,
    "title_bold": true
  },
  "document": {
    "max_words": 10000,
    "max_references": 50
  },
  "abbreviations": {
    "Fig.": "Figure",
    "Fig": "Figure",
    "Table": "Table",
    "et al.": "et al.",
    "vs.": "versus",
    "e.g.": "for example",
    "i.e.": "that is",
    "etc.": "et cetera",
    "approx.": "approximately",
    "max.": "maximum",
    "min.": "minimum"
  }
}
