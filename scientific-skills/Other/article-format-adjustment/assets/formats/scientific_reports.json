{
  "name": "Scientific Reports",
  "version": "1.0",
  "description": "Nature Publishing Group - Scientific Reports",
  "font": {
    "body": "Times New Roman",
    "body_size": 12,
    "title": "Times New Roman",
    "title_size": 18,
    "caption": "Times New Roman",
    "caption_size": 10,
    "header": "Times New Roman",
    "footer": "Times New Roman"
  },
  "spacing": {
    "line_space": "double",
    "paragraph_space": 6,
    "indent": 0.5
  },
  "margins": {
    "top": 2.54,
    "bottom": 2.54,
    "left": 2.54,
    "right": 2.54
  },
  "references": {
    "style": "Scientific Reports",
    "format": "numbered"
  },
  "figures": {
    "caption_position": "below",
    "font_size": 10,
    "font": "Times New Roman"
  },
  "tables": {
    "caption_position": "above",
    "font_size": 10,
    "font": "Times New Roman",
    "borders": true,
    "title_bold": true
  },
  "document": {
    "max_words": 4500,
    "max_references": 50,
    "max_figures": 8,
    "max_tables": 8
  },
  "abbreviations": {
    "Fig.": "Figure",
    "Table": "Table",
    "et al.": "et al.",
    "vs.": "versus",
    "e.g.": "for example",
    "i.e.": "that is",
    "etc.": "et cetera"
  }
}
