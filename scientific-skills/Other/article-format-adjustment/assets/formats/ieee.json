{
  "name": "IEEE",
  "version": "1.0",
  "font": {
    "body": "Times New Roman",
    "body_size": 10,
    "title": "Times New Roman",
    "title_size": 24,
    "caption": "Times New Roman",
    "caption_size": 8,
    "header": "Times New Roman",
    "footer": "Times New Roman"
  },
  "spacing": {
    "line_space": "double",
    "paragraph_space": 0,
    "indent": 0
  },
  "margins": {
    "top": 1.9,
    "bottom": 1.9,
    "left": 1.75,
    "right": 1.75
  },
  "references": {
    "style": "IEEE",
    "format": "numbered"
  },
  "figures": {
    "caption_position": "below",
    "font_size": 8,
    "font": "Times New Roman"
  },
  "tables": {
    "caption_position": "above",
    "font_size": 8,
    "font": "Times New Roman",
    "borders": true
  },
  "abbreviations": {
    "Fig.": "Figure",
    "TABLE": "Table"
  }
}
