{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["case_id", "setting", "patient", "chief_complaint", "history"],
  "properties": {
    "case_id": { "type": "string" },
    "setting": { "type": "string" },
    "chief_complaint": { "type": "string" },
    "patient": {
      "type": "object",
      "properties": {
        "age": { "type": "integer" },
        "sex": { "type": "string" },
        "pregnancy_possible": { "type": ["boolean", "string"] },
        "known_conditions": { "type": "array", "items": { "type": "string" } },
        "medications": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "history": {
      "type": "object",
      "properties": {
        "onset": { "type": "string" },
        "duration": { "type": "string" },
        "symptoms": { "type": "array", "items": { "type": "string" } },
        "associated_symptoms": { "type": "array", "items": { "type": "string" } },
        "vitals": { "type": "object" },
        "context": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
