{
  "name": "Cell Final File Requirements",
  "version": "1.0",
  "description": "Cell期刊终稿格式要求 - 基于CELLFFC.pdf",
  "font": {
    "body": "Arial",
    "body_size": 11,
    "title": "Arial",
    "title_size": 18,
    "caption": "Arial",
    "caption_size": 9,
    "header": "Arial",
    "footer": "Arial"
  },
  "spacing": {
    "line_space": "double",
    "paragraph_space": 0,
    "indent": 0
  },
  "margins": {
    "top": 2.54,
    "bottom": 2.54,
    "left": 2.54,
    "right": 2.54
  },
  "references": {
    "style": "Cell",
    "format": "numbered"
  },
  "figures": {
    "caption_position": "below",
    "font_size": 9,
    "font": "Arial",
    "title_required": true,
    "format": "Figure X. [Title]"
  },
  "tables": {
    "caption_position": "above",
    "font_size": 9,
    "font": "Arial",
    "title_required": true,
    "borders": true,
    "no_merged_cells": true,
    "no_colors": true
  },
  "document": {
    "max_words_article": 7000,
    "max_words_short": 4000,
    "summary_max_words": 150,
    "max_figures_tables_article": 7,
    "max_figures_tables_short": 4,
    "highlight_chars": 85,
    "sections_required": [
      "Title",
      "Author List and Affiliations",
      "Lead Contact",
      "Corresponding Author Email",
      "Summary",
      "Introduction",
      "Results",
      "Discussion",
      "Limitations of the Study",
      "Resource Availability",
      "Lead Contact Statement",
      "Materials Availability Statement",
      "Data and Code Availability Statement",
      "Acknowledgments",
      "Author Contributions",
      "Declaration of Interests",
      "Figure Legends",
      "Table Legends",
      "STAR Methods",
      "References"
    ]
  },
  "abbreviations": {
    "Fig.": "Figure",
    "et al.": "et alii"
  }
}
