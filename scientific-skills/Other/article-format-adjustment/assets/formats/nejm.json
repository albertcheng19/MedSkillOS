{
  "name": "NEJM",
  "version": "1.0",
  "description": "New England Journal of Medicine 医学期刊格式",
  "font": {
    "body": "Times New Roman",
    "body_size": 11,
    "title": "Times New Roman",
    "title_size": 16,
    "caption": "Times New Roman",
    "caption_size": 9,
    "header": "Times New Roman",
    "footer": "Times New Roman"
  },
  "spacing": {
    "line_space": "double",
    "paragraph_space": 0,
    "indent": 0
  },
  "margins": {
    "top": 2.54,
    "bottom": 2.54,
    "left": 2.54,
    "right": 2.54
  },
  "references": {
    "style": "NEJM",
    "format": "numbered"
  },
  "figures": {
    "caption_position": "below",
    "font_size": 9,
    "font": "Times New Roman"
  },
  "tables": {
    "caption_position": "above",
    "font_size": 9,
    "font": "Times New Roman",
    "borders": true
  },
  "abbreviations": {
    "CI": "confidence interval",
    "HR": "hazard ratio",
    "OR": "odds ratio",
    "P": "probability",
    "RR": "relative risk",
    "SD": "standard deviation",
    "SE": "standard error"
  }
}
